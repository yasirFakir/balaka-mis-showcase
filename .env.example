# ==============================================
# Backend Configuration (FastAPI)
# ==============================================

# Security
# Generate a strong key: `openssl rand -hex 32`
SECRET_KEY=change_this_to_a_secure_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# CORS
# Comma-separated list of allowed origins
BACKEND_CORS_ORIGINS=["*"]

# Database Connection
# ----------------------------------------------
# Option A: SQLite (Simpler for local dev)
# DATABASE_URL=sqlite:///./balaka_mis.db

# Option B: PostgreSQL (Recommended for production)
# If DATABASE_URL is not set, the app will construct it from these variables:
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=balaka_db
# ----------------------------------------------

# Email Configuration (Zoho SMTP)
# ----------------------------------------------
# Use App-Specific Password if 2FA is enabled
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_TLS=True
SMTP_USER=admin@airbalakatravel.com
SMTP_PASSWORD=your_secure_password
EMAILS_FROM_EMAIL=no-reply@balaka.com
EMAILS_FROM_NAME="Balaka Travel & Logistics"

# Root URL of the client portal (used for activation and reset links)
FRONTEND_HOST=http://localhost:3000


# ==============================================
# Frontend Configuration (Next.js)
# ==============================================

# API Base URL
# This tells the frontend where to find the backend.
NEXT_PUBLIC_API_URL=http://localhost:8008
