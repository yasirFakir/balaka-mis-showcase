{
  "name": "balaka-frontend-monorepo",
  "private": true,
  "scripts": {
    "dev:client": "npm run dev --workspace=balaka-client",
    "dev:admin": "npm run dev --workspace=balaka-admin",
    "build:client": "npm run build --workspace=balaka-client",
    "build:admin": "npm run build --workspace=balaka-admin",
    "setup-assets": "ln -sfn ../../../packages/assets apps/balaka-client/public/shared && ln -sfn ../../../packages/assets apps/balaka-admin/public/shared",
    "postinstall": "npm run setup-assets"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "next": "16.1.1",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5"
  },
  "dependencies": {
    "framer-motion": "^12.23.26",
    "nextjs-toploader": "^3.9.17"
  }
}
